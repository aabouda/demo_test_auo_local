{
  "env": {
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "indent": [
      "warn",
      2,
      {
        "SwitchCase": 1
      }
    ],
    "no-debugger": ["error"],
    "no-multiple-empty-lines": [
      "warn",
      {
        "max": 2,
        "maxEOF": 2
      }
    ],
    "semi": ["error", "always"]
  }
}
